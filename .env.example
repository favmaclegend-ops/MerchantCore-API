# Local Development / Production Template
# Copy to .env for local dev
# Use these keys to set Back4app environment variables for production

DATABASE_URL=mysql+pymysql://root@localhost:3306/merchant_core
SECRET_KEY=your-secret-key-here
DEBUG=false
ALLOWED_HOSTS=["*"]

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME="Merchant Core API"
